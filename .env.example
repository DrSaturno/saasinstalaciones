# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# URL pública exacta de la aplicación
APP_URL=http://localhost:3000

# Invitaciones por email (opcionales)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Web Push (opcional en el frontend)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Google Calendar (opcional; necesario para conectar y sincronizar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 32 bytes en base64. Ejemplo de generación: openssl rand -base64 32
GOOGLE_TOKEN_ENCRYPTION_KEY=
